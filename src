import csv
import matplotlib.pyplot as plt

def analyze(file):
    times = []
    vehicles = []

    with open(file) as f:
        reader = csv.DictReader(f)
        for row in reader:
            times.append(row['Simulation Time'])
            vehicles.append(int(row['Total Vehicles']))

    plt.plot(times, vehicles)
    plt.title("Traffic Analysis")
    plt.show()

if __name__ == "__main__":
    analyze("traffic_data.csv")

