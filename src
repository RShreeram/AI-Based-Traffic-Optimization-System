import os
import sys
import time
import logging
import traci
import sumolib
import requests
from datetime import datetime
import csv

logging.basicConfig(level=logging.INFO)

class SUMODataSender:
    def __init__(self, config_file, host, port):
        self.config_file = config_file
        self.host = host
        self.port = port
        self.output_csv = "traffic_data.csv"

    def setup_sumo(self):
        if 'SUMO_HOME' not in os.environ:
            raise EnvironmentError("SUMO_HOME not set")

        tools = os.path.join(os.environ['SUMO_HOME'], 'tools')
        sys.path.append(tools)

    def collect_data(self):
        vehicle_ids = traci.vehicle.getIDList()
        speeds = [traci.vehicle.getSpeed(v) for v in vehicle_ids]

        return {
            "total_vehicles": len(vehicle_ids),
            "avg_speed": sum(speeds)/len(speeds) if speeds else 0
        }

    def send_data(self, data):
        url = f"http://{self.host}:{self.port}/update"
        try:
            requests.post(url, json=data)
        except Exception as e:
            logging.error(e)

    def run(self):
        sumoBinary = sumolib.checkBinary('sumo-gui')
        traci.start([sumoBinary, "-c", self.config_file])

        while traci.simulation.getMinExpectedNumber() > 0:
            traci.simulationStep()

            data = self.collect_data()
            data["time"] = datetime.now().strftime("%H:%M:%S")

            print(data)
            self.send_data(data)

            time.sleep(0.1)

        traci.close()


if __name__ == "__main__":
    sender = SUMODataSender("osm.sumocfg", "127.0.0.1", 8080)
    sender.run()

